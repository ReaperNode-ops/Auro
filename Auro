      <button onClick={onReset} style={{width:"100%",padding:"12px",borderRadius:12,marginTop:8,fontFamily:"inherit",border:"1.5px solid "+C.border,background:"transparent",color:C.muted,fontSize:14,fontWeight:600,cursor:"pointer"}}>Start Over</button>
    </div>
  );
}


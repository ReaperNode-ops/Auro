function getAdaptiveQuestions(answers){
  return BASE_QUESTIONS.filter(q=>!q.condition||q.condition(answers));
}

function scoreOptions(answers){
  const skills=(answers.skills||[]).map(s=>s.toLowerCase());
  const interests=(answers.interests||[]).map(i=>i.toLowerCase());
  const budget=answers.budget||"";
  const incomeType=answers.income_type||"";
  const tech=answers.tech||"";
  const timeframe=answers.timeframe||"";
  const locationPref=answers.location_pref||"";
  const risk=answers.risk||"";
  const people=answers.people||"";
  const hasVehicle=answers.has_vehicle||"";
  const contentComfort=answers.content_comfort||"";
  const goal=answers.goal||"";

  const isZeroBudget=budget.includes("£0");
  const isLowBudget=budget.includes("£0")||budget.includes("Under");
  const wantsPassive=incomeType.includes("Passive");
  const wantsActive=incomeType.includes("Trade time");
  const isLowTech=tech.includes("Low")||tech.includes("Average");
  const isHighTech=tech.includes("Very");
  const needsFast=timeframe.includes("days")||timeframe.includes("month");
  const wantsRemote=locationPref.includes("Remote");
  const localOk=!locationPref.includes("Remote");
  const highRisk=risk.includes("High");
  const avoidsPeople=people.includes("alone");
  const likesPeople=people.includes("Love")||people.includes("Fine");
  const noVehicle=hasVehicle.includes("No vehicle");
  const wantsContent=contentComfort&&!contentComfort.includes("behind");
  const wantsWealth=goal.includes("long-term")||goal.includes("£10,000");

  return ALL_OPTIONS.map(opt=>{
    let score=40;
    const tags=opt.tags.map(t=>t.toLowerCase());

    skills.forEach(skill=>{
      const key=skill.split("/")[0].trim().toLowerCase();
      if(tags.some(t=>t.toLowerCase().includes(key)||key.includes(t.toLowerCase().split("/")[0]))) score+=28;
    });
    interests.forEach(interest=>{
      const key=interest.split("/")[0].trim().toLowerCase().replace(" & "," ");
      if(tags.some(t=>t.toLowerCase().includes(key)||key.includes(t.toLowerCase().replace(" & "," ")))) score+=16;
    });

    // Strong skill-to-option bonuses — prevent unrelated options crowding out obvious matches
    const skillsRaw=(answers.skills||[]);
    if(skillsRaw.some(s=>s.includes("Fitness"))){
      if(["personal-trainer","fitness-coach","nutrition-coach","yoga-instructor"].includes(opt.id)) score+=40;
    }
    if(skillsRaw.some(s=>s.includes("Coding"))){
      if(["freelance-dev","no-code-dev","web-dev","shopify-dev","saas","ai-automation","automation-specialist"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Writing"))){
      if(["copywriter","ghostwriter","blogger","newsletter","technical-writer"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Design"))){
      if(["graphic-design","ui-ux","motion-graphics","thumbnail-design","illustrator","print-on-demand"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Video"))){
      if(["video-editor","short-form-editor","youtube","videographer","ugc"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Music"))){
      if(["music-producer","dj","voice-actor","music-licensing"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Photography"))){
      if(["photographer","videographer","stock-photos"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Sales"))){
      if(["sales-rep","remote-closer","appointment-setter","recruiter","lead-gen"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Marketing"))){
      if(["seo","email-marketing","content-strategist","growth-operator","personal-brand","affiliate"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Teaching"))){
      if(["online-tutor","course-creator","fitness-coach","nutrition-coach"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Finance"))){
      if(["bookkeeping","data-analyst","real-estate","insurance-agent"].includes(opt.id)) score+=30;
    }
    if(skillsRaw.some(s=>s.includes("Hands-on"))){
      if(["electrician","plumber","carpenter","painter","mechanic","locksmith","general-contractor","solar-installer","barber","hair-stylist","tattoo-artist"].includes(opt.id)) score+=30;
    }

    if(isZeroBudget){
      if(tags.includes("no-budget")) score+=20;
      if(tags.includes("high-budget")) score-=50;
    }
    if(isLowBudget&&tags.includes("low-budget")) score+=10;

    if(wantsPassive&&tags.includes("passive")) score+=30;
    if(wantsActive&&tags.includes("active")) score+=25;
    if(wantsPassive&&!tags.includes("passive")&&tags.includes("active")) score-=10;

    if(needsFast&&tags.includes("fast")) score+=25;
    if(needsFast&&opt.difficulty==="Beginner") score+=10;
    if(needsFast&&tags.includes("long-term")) score-=25;

    if(isHighTech&&tags.includes("coding/tech")) score+=20;
    if(isLowTech&&opt.difficulty==="Advanced") score-=30;
    if(isLowTech&&tags.includes("coding/tech")) score-=20;

    if(wantsRemote&&tags.includes("local")&&!tags.includes("remote")) score-=35;
    if(wantsRemote&&tags.includes("remote")) score+=20;
    if(wantsRemote&&tags.includes("trades")) score-=35;
    if(localOk&&tags.includes("local")) score+=10;

    if(noVehicle&&tags.includes("vehicle")) score-=45;

    if(avoidsPeople&&tags.includes("people")) score-=20;
    if(likesPeople&&tags.includes("people")) score+=12;

    if(!highRisk&&(opt.id==="amazon-fba"||opt.id==="saas")) score-=15;
    if(highRisk&&tags.includes("high-income")) score+=15;

    if(wantsWealth&&tags.includes("passive")) score+=12;
    if(wantsWealth&&tags.includes("high-income")) score+=12;

    if(wantsContent&&(opt.id==="youtube"||opt.id==="tiktok"||opt.id==="ugc")) score+=20;
    if(!wantsContent&&(opt.id==="youtube"||opt.id==="tiktok")) score-=20;

    return {...opt,score};
  }).sort((a,b)=>b.score-a.score).slice(0,4);
}

function getArchetype(answers){
  const skills=(answers.skills||[]).map(s=>s.toLowerCase());
  const incomeType=answers.income_type||"";
  const goal=answers.goal||"";
  const risk=answers.risk||"";
  const tech=answers.tech||"";

  const isCreative=skills.some(s=>["design","writing","music","photography","video"].some(c=>s.includes(c)));
  const isBusiness=skills.some(s=>["sales","marketing","finance"].some(c=>s.includes(c)));
  const isTech=skills.some(s=>s.includes("coding"));
  const isTeacher=skills.some(s=>s.includes("teaching"));
  const isHandsOn=skills.some(s=>s.includes("hands-on"));
  const wantsPassive=incomeType.includes("Passive");
  const needsFast=goal.includes("Quick");
  const isAmbitious=goal.includes("£10,000")||risk.includes("High");
  const isHighTech=tech.includes("Very");

  if(isTech&&isHighTech) return{name:"The Builder",desc:"Your technical skills open doors most people can't access. Use them to build scalable, high-income streams."};
  if(isCreative&&wantsPassive) return{name:"The Creative Earner",desc:"Your creativity is your biggest asset — build passive income streams around what you love making."};
  if(isBusiness) return{name:"The Strategic Hustler",desc:"You have the commercial instincts to turn skills into serious income fast. Focus and execute."};
  if(isTeacher) return{name:"The Knowledge Seller",desc:"What you know has real value. People will pay well to learn from someone who can explain it clearly."};
  if(isHandsOn) return{name:"The Skilled Operator",desc:"Hands-on skills are in short supply and high demand. Build your trade and your reputation."};
  if(isAmbitious) return{name:"The Empire Builder",desc:"You're not here for pocket money — you want something serious. Think big, start focused."};
  if(needsFast) return{name:"The Fast Mover",desc:"You need results quickly. These strategies are optimised for speed over long-term scale."};
  if(wantsPassive) return{name:"The Passive Income Seeker",desc:"You want money working for you. The right systems built now will pay off for years."};
  return{name:"The Side Hustle Starter",desc:"You're building income streams that fit around your life — and that's exactly how the best businesses start."};
}

function QuestionCard({question,onAnswer,progress,total}){
  const [selected,setSelected]=useState(question.type==="multiselect"?[]:null);
  useEffect(()=>{setSelected(question.type==="multiselect"?[]:null);},[question.id]);
  const handleSelect=(opt)=>{
    if(question.type==="multiselect"){
      setSelected(prev=>prev.includes(opt)?prev.filter(v=>v!==opt):[...prev,opt]);
    }else{
      setSelected(opt);
      setTimeout(()=>onAnswer(opt),180);
    }
  };
  const canContinue=question.type==="multiselect"?selected.length>0:selected!==null;
  const pct=Math.round((progress/total)*100);
  return(
    <div style={{animation:"slideIn 0.3s ease"}}>
      <div style={{marginBottom:24}}>
        <div style={{display:"flex",justifyContent:"space-between",marginBottom:7}}>
          <span style={{fontSize:11,fontWeight:700,color:C.accent,letterSpacing:1,textTransform:"uppercase"}}>Question {progress} of ~{total}</span>
          <span style={{fontSize:11,color:C.muted}}>{pct}%</span>
        </div>
        <div style={{height:4,background:C.border,borderRadius:2,overflow:"hidden"}}>
          <div style={{height:"100%",width:pct+"%",background:C.grad,borderRadius:2,transition:"width 0.4s ease"}}/>
        </div>
      </div>
      <h2 style={{fontSize:19,fontWeight:800,color:C.text,marginBottom:18,lineHeight:1.3,fontFamily:"Georgia,serif"}}>{question.text}</h2>
      <div style={{display:"flex",flexDirection:"column",gap:8,marginBottom:16}}>
        {question.options.map(opt=>{
          const isSel=question.type==="multiselect"?selected.includes(opt):selected===opt;
          return(
            <button key={opt} onClick={()=>handleSelect(opt)} style={{padding:"11px 14px",borderRadius:10,textAlign:"left",fontFamily:"inherit",border:"1.5px solid "+(isSel?C.primary:C.border),background:isSel?C.surfaceAlt:C.surface,color:isSel?C.primary:C.text,fontSize:14,fontWeight:isSel?600:400,cursor:"pointer",transition:"all 0.15s",display:"flex",alignItems:"center",gap:10}}>
              <div style={{width:16,height:16,borderRadius:question.type==="multiselect"?4:"50%",border:"2px solid "+(isSel?C.primary:C.border),background:isSel?C.primary:"transparent",flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",transition:"all 0.15s"}}>
                {isSel&&<svg width="8" height="6" viewBox="0 0 8 6" fill="none"><path d="M1 3L3 5L7 1" stroke="white" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"/></svg>}
              </div>
              {opt}
            </button>
          );
        })}
      </div>
      {question.type==="multiselect"&&(
        <button onClick={()=>canContinue&&onAnswer(selected)} disabled={!canContinue} style={{width:"100%",padding:"13px",borderRadius:12,border:"none",fontFamily:"inherit",background:canContinue?C.grad:C.border,color:canContinue?"#fff":C.muted,fontSize:15,fontWeight:700,cursor:canContinue?"pointer":"not-allowed",transition:"all 0.2s"}}>
          Continue{canContinue?" ("+selected.length+" selected)":""}
        </button>
      )}
    </div>
  );
}


